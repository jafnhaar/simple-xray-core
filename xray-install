#!/bin/bash
set -euo pipefail

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
BLUE='\033[0;34m'; CYAN='\033[0;36m'; BOLD='\033[1m'; RESET='\033[0m'

ok()   { echo -e "${GREEN}✔${RESET}  $*"; }
info() { echo -e "${CYAN}→${RESET}  $*"; }
warn() { echo -e "${YELLOW}⚠${RESET}  $*"; }
die()  { echo -e "${RED}✘${RESET}  $*" >&2; exit 1; }
sep()  { echo -e "${BLUE}──────────────────────────────────────────────${RESET}"; }

XRAY_CONFIG="/usr/local/etc/xray/config.json"
XRAY_SERVICE="xray"
SCRIPT_PATH="$(realpath "$0")"
CRON_TAG="# xray-manage auto-update"

info "Будет установлен Vless с транспортом TCP"

ensure_deps() {
    local pkgs=()
    command -v curl     &>/dev/null || pkgs+=(curl)
    command -v jq       &>/dev/null || pkgs+=(jq)
    command -v qrencode &>/dev/null || pkgs+=(qrencode)
    command -v openssl  &>/dev/null || pkgs+=(openssl)
    if [[ ${#pkgs[@]} -gt 0 ]]; then
        info "Installing dependencies: ${pkgs[*]}"
        apt-get update -qq
        apt-get install -y -qq "${pkgs[@]}"
    fi
}

xray_installed_version() {
    /usr/local/bin/xray version 2>/dev/null | awk 'NR==1{print $2}' || echo "none"
}

xray_latest_version() {
    curl -fsSL "https://api.github.com/repos/XTLS/Xray-core/releases/latest" \
        | grep '"tag_name"' | sed 's/.*"v\([^"]*\)".*/\1/'
}

install_xray() {
    ensure_deps
    local ver
    ver=$(xray_latest_version)
    [[ -z "$ver" ]] && die "Could not fetch latest Xray version from GitHub"
    local current
    current=$(xray_installed_version)
    if [[ "$current" == "$ver" ]]; then
        ok "Xray is already up to date (v${ver})"
    else
        info "Installing Xray v${ver} (was: ${current})"
        local arch
        arch=$(uname -m)
        case "$arch" in
            x86_64)  arch_str="64" ;;
            aarch64) arch_str="arm64-v8a" ;;
            armv7*)  arch_str="arm32-v7a" ;;
            *)       die "Unsupported architecture: $arch" ;;
        esac
        WORK_DIR=$(mktemp -d)
        local url="https://github.com/XTLS/Xray-core/releases/download/v${ver}/Xray-linux-${arch_str}.zip"
        info "Downloading from: $url"
        curl -fsSL "$url" -o "$WORK_DIR/xray.zip"
        apt-get install -y -qq unzip &>/dev/null
        unzip -q "$WORK_DIR/xray.zip" -d "$WORK_DIR/xray"
        install -m 755 "$WORK_DIR/xray/xray" /usr/local/bin/xray
        ok "Xray v${ver} installed"
    fi
    update_geo
    setup_systemd
}

sysctl_tune() {
    local params=(
        "net.core.default_qdisc=fq"
        "net.ipv4.tcp_congestion_control=bbr"
    )
    for param in "${params[@]}"; do
        local key="${param%%=*}"
        local value="${param#*=}"
        if sysctl -n "$key" 2>/dev/null | grep -q "$value"; then
            ok "$key is already set to $value"
        else
            echo "$param" >> /etc/sysctl.conf
            sysctl -w "$param" &>/dev/null
            ok "Set $key to $value"
        fi
    done
}

update_geo() {
    local geoip_url="https://github.com/Loyalsoldier/v2ray-rules-dat/raw/release/geoip.dat"
    local geosite_url="https://github.com/Loyalsoldier/v2ray-rules-dat/raw/release/geosite.dat"
    local GEO_DIR="/usr/local/share/xray"

    info "Updating geo files..."
    mkdir -p "$GEO_DIR"

    local tmp_ip tmp_site
    tmp_ip=$(mktemp)
    tmp_site=$(mktemp)

    if curl -fsSL --progress-bar "$geoip_url" -o "$tmp_ip"; then
        mv "$tmp_ip" "${GEO_DIR}/geoip.dat"
        chmod 644 "${GEO_DIR}/geoip.dat"
        ok "geoip.dat updated ($(du -sh "${GEO_DIR}/geoip.dat" | cut -f1))"
    else
        rm -f "$tmp_ip"
        warn "Failed to download geoip.dat — keeping existing file"
    fi

    if curl -fsSL --progress-bar "$geosite_url" -o "$tmp_site"; then
        mv "$tmp_site" "${GEO_DIR}/geosite.dat"
        chmod 644 "${GEO_DIR}/geosite.dat"
        ok "geosite.dat updated ($(du -sh "${GEO_DIR}/geosite.dat" | cut -f1))"
    else
        rm -f "$tmp_site"
        warn "Failed to download geosite.dat — keeping existing file"
    fi
}

setup_systemd() {
    if [[ ! -f /etc/systemd/system/xray.service ]]; then
        info "Creating systemd service..."
        cat > /etc/systemd/system/xray.service <<'EOF'
[Unit]
Description=Xray Service
Documentation=https://github.com/xtls
After=network.target nss-lookup.target

[Service]
User=nobody
CapabilityBoundingSet=CAP_NET_ADMIN CAP_NET_BIND_SERVICE
AmbientCapabilities=CAP_NET_ADMIN CAP_NET_BIND_SERVICE
NoNewPrivileges=true
ExecStart=/usr/local/bin/xray run -config /usr/local/etc/xray/config.json
Restart=on-failure
RestartPreventExitStatus=23
LimitNPROC=10000
LimitNOFILE=1000000

[Install]
WantedBy=multi-user.target
EOF
        systemctl daemon-reload
        systemctl enable xray &>/dev/null
        ok "Systemd service created and enabled"
    fi
    ensure_base_config
    systemctl restart xray && ok "Xray service started" || warn "Service start failed — check: journalctl -u xray -n 30"
}

ensure_base_config() {
    mkdir -p "$(dirname "$XRAY_CONFIG")"
    if [[ ! -f "$XRAY_CONFIG" ]]; then
        warn "No config found — generating fresh config with TCP+REALITY on 443"

        # Verify xray binary is usable before calling it
        [[ -x /usr/local/bin/xray ]] || die "xray binary not found at /usr/local/bin/xray"

        # Generate all dynamic values BEFORE the heredoc — no subshells inside heredoc
        local kp_tcp
        kp_tcp=$(/usr/local/bin/xray x25519 2>&1)

        local privkey_tcp pubkey_tcp
        privkey_tcp=$(echo   "$kp_tcp"   | awk '/PrivateKey:|Private key/{print $NF}')
        pubkey_tcp=$(echo    "$kp_tcp"   | awk '/PublicKey\):|^PublicKey:|Public key/{print $NF}')

        [[ -n "$privkey_tcp"   ]] || die "Failed to generate TCP key pair (xray x25519 returned: $kp_tcp)"
        [[ -n "$pubkey_tcp"    ]] || die "Failed to parse TCP public key"

        local shortid_tcp
        shortid_tcp=$(openssl rand -hex 8)

        local main_uuid=$(/usr/local/bin/xray uuid)

        local ip=$(curl api.ipify.org -4 -s)

        cat > "$XRAY_CONFIG" <<EOF
{
  "_comment_tcp_pubkey": "${pubkey_tcp}",
  "_comment_tcp_shortid": "${shortid_tcp}",
  "log": {
    "loglevel": "warning"
  },
  "inbounds": [
    {
      "_tag": "tcp-reality",
      "listen": "0.0.0.0",
      "port": 443,
      "protocol": "vless",
      "settings": {
        "clients": [
            {
                "email": "main",
                "id": "${main_uuid}",
                "flow": "xtls-rprx-vision"
            }
        ],
        "decryption": "none"
      },
      "streamSettings": {
        "network": "tcp",
        "security": "reality",
        "realitySettings": {
          "show": false,
          "dest": "www.microsoft.com:443",
          "xver": 0,
          "serverNames": ["www.microsoft.com"],
          "privateKey": "${privkey_tcp}",
          "shortIds": ["${shortid_tcp}"]
        }
      },
      "sniffing": {
        "enabled": true,
        "destOverride": ["http", "tls", "quic"]
      }
    }
  ],
  "outbounds": [
    {
      "protocol": "freedom",
      "tag": "direct"
    },
    {
      "protocol": "blackhole",
      "tag": "block"
    }
  ],
  "routing": {
    "domainStrategy": "IPIfNonMatch",
    "rules": [
      {
        "type": "field",
        "ip": ["geoip:private"],
        "outboundTag": "block"
      },
      {
        "type": "field",
        "domain": ["geosite:category-ads-all"],
        "outboundTag": "block"
      }
    ]
  }
}
EOF
        # Verify the written config is valid JSON before proceeding
        jq empty "$XRAY_CONFIG" || die "Config file is not valid JSON — check $XRAY_CONFIG"

        ok "Config written to $XRAY_CONFIG"
        echo ""
        echo -e "  ${BOLD}TCP  REALITY public key :${RESET} ${pubkey_tcp}"
        echo -e "  ${BOLD}TCP  short ID           :${RESET} ${shortid_tcp}"
        echo ""
        echo -e "vless://$main_uuid@${ip}:443?security=reality&sni=www.microsoft.com&fp=randomized&pbk=${pubkey_tcp}&sid=${shortid_tcp}&spx=/&type=tcp&flow=xtls-rprx-vision&encryption=none#vless_${ip}"
    fi
}

sysctl_tune
update_geo
install_xray
setup_systemd

# Исполняемый файл для списка клиентов
touch /usr/local/bin/userlist
cat << 'EOF' > /usr/local/bin/userlist
#!/bin/bash
emails=($(jq -r '.inbounds[0].settings.clients[].email' "/usr/local/etc/xray/config.json"))

if [[ ${#emails[@]} -eq 0 ]]; then
    echo "Список клиентов пуст"
    exit 1
fi

echo "Список клиентов:"
for i in "${!emails[@]}"; do
    echo "$((i+1)). ${emails[$i]}"
done
EOF
chmod +x /usr/local/bin/userlist

# исполняемый файл для ссылки основного пользователя
touch /usr/local/bin/mainuser
cat << 'EOF' > /usr/local/bin/mainuser
#!/bin/bash
protocol=$(jq -r '.inbounds[0].protocol' /usr/local/etc/xray/config.json)
port=$(jq -r '.inbounds[0].port' /usr/local/etc/xray/config.json)
uuid=$(cat /usr/local/etc/xray/.keys | awk -F': ' '/uuid/ {print $2}')
pbk=$(jq -r '._comment_tcp_pubkey' /usr/local/etc/xray/config.json)
sid=$(jq -r '._comment_tcp_shortid' /usr/local/etc/xray/config.json)
sni=$(jq -r '.inbounds[0].streamSettings.realitySettings.serverNames[0]' /usr/local/etc/xray/config.json)
ip=$(curl api.ipify.org -4 -s)
link="$protocol://$uuid@$ip:$port?security=reality&sni=$sni&fp=randomized&pbk=$pbk&sid=$sid&spx=/&type=tcp&flow=xtls-rprx-vision&encryption=none#vless-$ip"
echo ""
echo "Ссылка для подключения":
echo "$link"
echo ""
echo "QR-код:"
echo ${link} | qrencode -t ansiutf8
EOF
chmod +x /usr/local/bin/mainuser

# Исполняемый файл для создания новых клиентов
touch /usr/local/bin/newuser
cat << 'EOF' > /usr/local/bin/newuser
#!/bin/bash
read -p "Введите имя пользователя (email): " email

    if [[ -z "$email" || "$email" == *" "* ]]; then
    echo "Имя пользователя не может быть пустым или содержать пробелы. Попробуйте снова."
    exit 1
    fi
user_json=$(jq --arg email "$email" '.inbounds[0].settings.clients[] | select(.email == $email)' /usr/local/etc/xray/config.json)

if [[ -z "$user_json" ]]; then
uuid=$(xray uuid)
jq --arg email "$email" --arg uuid "$uuid" '.inbounds[0].settings.clients += [{"email": $email, "id": $uuid, "flow": "xtls-rprx-vision"}]' /usr/local/etc/xray/config.json > tmp.json && mv tmp.json /usr/local/etc/xray/config.json
systemctl restart xray
index=$(jq --arg email "$email" '.inbounds[0].settings.clients | to_entries[] | select(.value.email == $email) | .key'  /usr/local/etc/xray/config.json)
protocol=$(jq -r '.inbounds[0].protocol' /usr/local/etc/xray/config.json)
port=$(jq -r '.inbounds[0].port' /usr/local/etc/xray/config.json)
uuid=$(jq --argjson index "$index" -r '.inbounds[0].settings.clients[$index].id' /usr/local/etc/xray/config.json)
pbk=$(jq -r '._comment_tcp_pubkey' /usr/local/etc/xray/config.json)
sid=$(jq -r '._comment_tcp_shortid' /usr/local/etc/xray/config.json)
username=$(jq --argjson index "$index" -r '.inbounds[0].settings.clients[$index].email' /usr/local/etc/xray/config.json)
sni=$(jq -r '.inbounds[0].streamSettings.realitySettings.serverNames[0]' /usr/local/etc/xray/config.json)
ip=$(curl -4 -s icanhazip.com)
link="$protocol://$uuid@$ip:$port?security=reality&sni=$sni&fp=firefox&pbk=$pbk&sid=$sid&spx=/&type=tcp&flow=xtls-rprx-vision&encryption=none#$username"
echo ""
echo "Ссылка для подключения":
echo "$link"
echo ""
echo "QR-код:"
echo ${link} | qrencode -t ansiutf8
else
echo "Пользователь с таким именем уже существует. Попробуйте снова." 
fi
EOF
chmod +x /usr/local/bin/newuser

# Исполняемый файл для удаления клиентов
touch /usr/local/bin/rmuser
cat << 'EOF' > /usr/local/bin/rmuser
#!/bin/bash
emails=($(jq -r '.inbounds[0].settings.clients[].email' "/usr/local/etc/xray/config.json"))

if [[ ${#emails[@]} -eq 0 ]]; then
    echo "Нет клиентов для удаления."
    exit 1
fi

echo "Список клиентов:"
for i in "${!emails[@]}"; do
    echo "$((i+1)). ${emails[$i]}"
done

read -p "Введите номер клиента для удаления: " choice

if ! [[ "$choice" =~ ^[0-9]+$ ]] || (( choice < 1 || choice > ${#emails[@]} )); then
    echo "Ошибка: номер должен быть от 1 до ${#emails[@]}"
    exit 1
fi

selected_email="${emails[$((choice - 1))]}"

jq --arg email "$selected_email" \
   '(.inbounds[0].settings.clients) |= map(select(.email != $email))' \
   "/usr/local/etc/xray/config.json" > tmp && mv tmp "/usr/local/etc/xray/config.json"

systemctl restart xray

echo "Клиент $selected_email удалён."
EOF
chmod +x /usr/local/bin/rmuser

# Исполняемый файл для вывода списка пользователей и создания ссылкок
touch /usr/local/bin/sharelink
cat << 'EOF' > /usr/local/bin/sharelink
#!/bin/bash
emails=($(jq -r '.inbounds[0].settings.clients[].email' /usr/local/etc/xray/config.json))

for i in "${!emails[@]}"; do
   echo "$((i + 1)). ${emails[$i]}"
done

read -p "Выберите клиента: " client

if ! [[ "$client" =~ ^[0-9]+$ ]] || (( client < 1 || client > ${#emails[@]} )); then
    echo "Ошибка: номер должен быть от 1 до ${#emails[@]}"
    exit 1
fi

selected_email="${emails[$((client - 1))]}"


index=$(jq --arg email "$selected_email" '.inbounds[0].settings.clients | to_entries[] | select(.value.email == $email) | .key'  /usr/local/etc/xray/config.json)
protocol=$(jq -r '.inbounds[0].protocol' /usr/local/etc/xray/config.json)
port=$(jq -r '.inbounds[0].port' /usr/local/etc/xray/config.json) 
uuid=$(jq --argjson index "$index" -r '.inbounds[0].settings.clients[$index].id' /usr/local/etc/xray/config.json)
pbk=$(jq -r '._comment_tcp_pubkey' /usr/local/etc/xray/config.json)
sid=$(jq -r '._comment_tcp_shortid' /usr/local/etc/xray/config.json)
username=$(jq --argjson index "$index" -r '.inbounds[0].settings.clients[$index].email' /usr/local/etc/xray/config.json)
sni=$(jq -r '.inbounds[0].streamSettings.realitySettings.serverNames[0]' /usr/local/etc/xray/config.json)
ip=$(curl -4 -s icanhazip.com)
link="$protocol://$uuid@$ip:$port?security=reality&sni=$sni&fp=firefox&pbk=$pbk&sid=$sid&spx=/&type=tcp&flow=xtls-rprx-vision&encryption=none#$username"
echo ""
echo "Ссылка для подключения":
echo "$link"
echo ""
echo "QR-код:"
echo ${link} | qrencode -t ansiutf8
EOF
chmod +x /usr/local/bin/sharelink

info "Xray-core успешно установлен"

# Создаем файл с подсказками
touch $HOME/help
cat << 'EOF' > $HOME/help

Команды для управления пользователями Xray:

    mainuser - выводит ссылку для подключения основного пользователя
    newuser - создает нового пользователя
    rmuser - удаление пользователей
    sharelink - выводит список пользователей и позволяет создать для них ссылки для подключения
    userlist - выводит список клиентов



Файл конфигурации находится по адресу:

    /usr/local/etc/xray/config.json

Команда для перезагрузки ядра Xray:

    systemctl restart xray

EOF
